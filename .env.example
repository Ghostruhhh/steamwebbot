STEAM_API_KEY=your_steam_web_api_key_here
PORT=3000

# Optional: Battlemetrics Bearer token → Rust BM tracked-server hours alongside Steam lookups
# https://www.battlemetrics.com/developers
BATTLEMETRICS_TOKEN=

# Optional: paths are relative to this folder OR absolute Windows paths like C:\\Apps\\checker.exe
# The hub can run this .exe on your PC via Node — browser must still use localhost or 127.0.0.1
SERIAL_CHECKER_EXE=
# Extra CLI tokens (space-separated)
SERIAL_CHECKER_ARGS=
# SERIAL_CHECKER_TIMEOUT_MS=90000   # execFile capture mode only; ignored when detach:true

# Optional: Defender CLI quick-scan can take several minutes — raise if Node kills MpCmdRun early (ms).
# DEFENDER_SCAN_TIMEOUT_MS=720000

# Optional: web + CLI loaders — two-step delivery (recommended):
# 1) Browser /loader/ with delivery:web → LOADER_BOOTSTRAP_EXE_PATH (usually dist\GalaxyLoader.exe)
# 2) Buyer runs that exe, enters key again → LOADER_ARTIFACT_PATH (your real product installer)
# LOADER_BOOTSTRAP_EXE_PATH=dist\GalaxyLoader.exe
# Optional filename in Save dialog for the bootstrap download (default: basename of that file)
# LOADER_CLIENT_DOWNLOAD_FILENAME=GalaxyLoader.exe
#
# Product installer path (CLI / desktop loader always receives this after activate; browser does if bootstrap is unset)
# You MUST place a REAL .exe on disk (your product installer — or any file for staging).
# Paths are relative to the folder containing server.js, or absolute, e.g. C:\Ship\MyInstaller.exe
# LOADER_ARTIFACT_PATH=artifacts\MyInstaller.exe
# Optional filename shown in browser Save dialog:
# LOADER_DOWNLOAD_FILENAME=MyProduct-Installer.exe
# Optional — sign download links (recommended in production, min 16 random chars).
# LOADER_DOWNLOAD_SECRET=
# LOADER_DOWNLOAD_TTL_SEC=900

# Optional: POST /api/license/verify-runtime (EXE startup checks). Defaults: 3600000 ms window, 180 requests/window/IP.
# LICENSE_VERIFY_WINDOW_MS=
# LICENSE_VERIFY_MAX=
